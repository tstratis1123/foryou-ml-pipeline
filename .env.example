# AWS Configuration
AWS_REGION=us-east-1
S3_BUCKET=foryou-ml-assets
SQS_TRAINING_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/foryou-training
SQS_GENERATION_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/foryou-generation

# Model Defaults
BASE_MODEL_ID=stabilityai/stable-diffusion-xl-base-1.0
LORA_RANK=16
TRAINING_STEPS=1000
LEARNING_RATE=1e-4

# Generation
DEFAULT_GUIDANCE_SCALE=7.5
DEFAULT_NUM_INFERENCE_STEPS=50
IMAGE_RESOLUTION=1024

# Moderation
NSFW_THRESHOLD=0.85

# Watermark
WATERMARK_KEY=change-me-in-production
WATERMARK_STRENGTH=0.1
VIDEOSEAL_MODEL_PATH=/models/videoseal/model.pt

# Runtime
DEVICE=cuda
